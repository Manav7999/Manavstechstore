{
  "name": "manavstech-store",
  "version": "1.0.0",
  "description": "Root workspace for ManavsTech Store monorepo",
  "type": "module",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build": "npm --prefix frontend run build",
    "start": "npm --prefix frontend run start",
    "install:all": "npm install --prefix frontend && npm install --prefix backend"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "railway": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
